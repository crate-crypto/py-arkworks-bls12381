__all__ = ["G1Point", "G2Point", "GT", "Scalar"]

class G1Point:
    def __new__(cls) -> G1Point: ...
    @staticmethod
    def identity() -> G1Point: ...
    def __add__(self, rhs: G1Point) -> G1Point: ...
    def __sub__(self, rhs: G1Point) -> G1Point: ...
    def __mul__(self, rhs: Scalar) -> G1Point: ...
    def __neg__(self) -> G1Point: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __str__(self) -> str: ...
    def is_in_subgroup(self) -> bool: ...
    def to_compressed_bytes(self) -> bytes: ...
    @staticmethod
    def from_compressed_bytes(bytes: bytes) -> G1Point: ...
    @staticmethod
    def from_compressed_bytes_unchecked(bytes: bytes) -> G1Point: ...
    def to_xy_bytes_be(self) -> bytes: ...
    def to_xy_bytes_le(self) -> bytes: ...
    @staticmethod
    def from_xy_bytes_be(bytes: bytes) -> G1Point: ...
    @staticmethod
    def from_xy_bytes_le(bytes: bytes) -> G1Point: ...
    @staticmethod
    def from_xy_bytes_unchecked_be(bytes: bytes) -> G1Point: ...
    @staticmethod
    def from_xy_bytes_unchecked_le(bytes: bytes) -> G1Point: ...
    @staticmethod
    def map_from_fp_be(fp_bytes: bytes) -> G1Point: ...
    @staticmethod
    def map_from_fp_le(fp_bytes: bytes) -> G1Point: ...
    @staticmethod
    def multiexp_unchecked(points: list[G1Point], scalars: list[Scalar]) -> G1Point: ...

