class Scalar:
    def __new__(cls, integer: int) -> Scalar: ...
    def __add__(self, rhs: Scalar) -> Scalar: ...
    def __sub__(self, rhs: Scalar) -> Scalar: ...
    def __mul__(self, rhs: Scalar) -> Scalar: ...
    def __truediv__(self, rhs: Scalar) -> Scalar: ...
    def __neg__(self) -> Scalar: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __str__(self) -> str: ...
    def __int__(self) -> int: ...
    def pow(self, exp: Scalar) -> Scalar: ...
    def square(self) -> Scalar: ...
    def inverse(self) -> Scalar: ...
    def is_zero(self) -> bool: ...
    def is_one(self) -> bool: ...
    def to_le_bytes(self) -> bytes: ...
    @staticmethod
    def from_le_bytes(bytes: bytes) -> Scalar: ...
    def to_be_bytes(self) -> bytes: ...
    @staticmethod
    def from_be_bytes(bytes: bytes) -> Scalar: ...

class GT:
    def __new__(cls) -> GT: ...
    @staticmethod
    def zero() -> GT: ...
    @staticmethod
    def one() -> GT: ...
    @staticmethod
    def multi_pairing(g1s: list[G1Point], g2s: list[G2Point]) -> GT: ...
    @staticmethod
    def pairing(g1: G1Point, g2: G2Point) -> GT: ...
    @staticmethod
    def pairing_check(g1s: list[G1Point], g2s: list[G2Point]) -> bool: ...
    def __add__(self, rhs: GT) -> GT: ...
    def __sub__(self, rhs: GT) -> GT: ...
    def __mul__(self, rhs: GT) -> GT: ...
    def __neg__(self) -> GT: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __str__(self) -> str: ...
